# =============================================================================
# .env.example – WhisperX ASR Service Configuration
# Copy to .env and fill in your values
# =============================================================================

# ---------------------------
# HuggingFace (REQUIRED for pyannote diarization models)
# Get token at: https://huggingface.co/settings/tokens
# Accept all 3 model agreements before first use:
#   https://huggingface.co/pyannote/speaker-diarization-community-1
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
# ---------------------------
HF_TOKEN=hf_REPLACE_WITH_YOUR_TOKEN

# ---------------------------
# Compute settings
# ---------------------------
# Device: cuda (GPU) or cpu
DEVICE=cuda

# Precision: float16 (recommended for Blackwell), float32 (CPU), int8 (fast, lower quality)
COMPUTE_TYPE=float16

# Batch size: RTX 6000 Blackwell has 48GB VRAM – can go high
# 16 = conservative, 32 = good for large-v3, 64 = aggressive (watch VRAM)
BATCH_SIZE=32

# ---------------------------
# Model
# ---------------------------
# Preload at startup (reduces first-request latency)
# Options: tiny, base, small, medium, large-v2, large-v3
PRELOAD_MODEL=large-v3

# Maximum audio file size to accept (MB)
MAX_FILE_SIZE_MB=4000

# ---------------------------
# Serving mode
# ---------------------------
# simple: single uvicorn process, async GPU queue (good for dev/single GPU)
# ray:    Ray Serve with batching (recommended for 8 GPUs)
SERVE_MODE=simple
# SERVE_MODE=ray
# PIPELINE_STRATEGY=replicate
# NUM_GPU_REPLICAS=8

# ---------------------------
# Offline mode
# ---------------------------
# Set to 1 AFTER first successful run to prevent all HF network calls
# (Required for fully air-gapped operation)
HF_HUB_OFFLINE=0

# ---------------------------
# Advanced
# ---------------------------
# GPU concurrency (how many pipeline runs at once in simple mode)
GPU_CONCURRENCY=1

# Idle model eviction (0 = disabled; 3600 = evict after 1 hour idle)
MODEL_KEEP_ALIVE_SECONDS=0
MODEL_EVICTION_INTERVAL_SECONDS=60

# PyTorch weights safety workaround (needed for pyannote on PyTorch >= 2.6)
TORCH_FORCE_NO_WEIGHTS_ONLY_LOAD=true
